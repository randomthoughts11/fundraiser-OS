# ─── Neon (PostgreSQL) ───────────────────────────────────────────────────────
# Pooled connection — use for the app (Vercel, local dev)
# Neon Console → Connection Details → "Pooled connection"
DATABASE_URL="postgresql://[user]:[password]@[endpoint]-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct connection — use for migrations and db push only
# Neon Console → Connection Details → "Direct connection"
DIRECT_URL="postgresql://[user]:[password]@[endpoint].us-east-1.aws.neon.tech/neondb?sslmode=require"

# Optional: Neon project ID (set by `npx neonctl@latest init`)
NEON_PROJECT_ID=

# ─── Clerk Auth ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── S3 / R2 (deck storage) — optional ───────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ─── Inngest (background jobs) ───────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Upstash Redis (rate limits) — optional ──────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── PostHog (analytics) — optional ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Gmail OAuth — optional ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# ─── App ─────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=change-me-to-a-random-32-char-string
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev only: skip Clerk when keys are empty (never enable in production)
AUTH_BYPASS_DEV=true
